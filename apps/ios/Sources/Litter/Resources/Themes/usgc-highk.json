{
  "name": "USGC High-K",
  "type": "light",
  "colors": {
    "activityBar.background": "#EDEDED",
    "activityBar.foreground": "#000000",
    "button.background": "#0000FF",
    "button.foreground": "#FFFFFF",
    "button.hoverBackground": "#00FF00",
    "editor.background": "#FFFFFF",
    "editor.foreground": "#000000",
    "editor.lineHighlightBackground": "#00FF00",
    "editor.selectionBackground": "#00FF00",
    "editorCursor.foreground": "#0000FF",
    "editorGroup.border": "#999999",
    "editorGroupHeader.tabsBackground": "#F5F5F5",
    "editorLineNumber.foreground": "#FF0000",
    "editorLineNumber.activeForeground": "#000000",
    "panel.background": "#F5F5F5",
    "panel.border": "#999999",
    "sideBar.background": "#F5F5F5",
    "sideBar.foreground": "#000000",
    "sideBar.border": "#999999",
    "sideBarTitle.foreground": "#000000",
    "statusBar.background": "#FFFFFF",
    "statusBar.foreground": "#0000FF",
    "textLink.foreground": "#0000FF",
    "gitDecoration.addedResourceForeground": "#00A645",
    "gitDecoration.deletedResourceForeground": "#FF0000"
  },
  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#999999" } },
    { "scope": ["string", "constant.other.symbol"], "settings": { "foreground": "#006666" } },
    { "scope": ["constant.numeric", "constant.language.boolean"], "settings": { "foreground": "#660066" } },
    { "scope": ["keyword", "storage", "storage.type", "storage.modifier"], "settings": { "foreground": "#0000FF" } },
    { "scope": ["entity.name.function", "support.function", "variable.function"], "settings": { "foreground": "#00A645" } },
    { "scope": ["variable", "variable.parameter"], "settings": { "foreground": "#000000" } }
  ]
}
