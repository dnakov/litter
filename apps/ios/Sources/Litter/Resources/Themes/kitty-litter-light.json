{
  "name": "Kitty Litter Light",
  "type": "light",
  "colors": {
    "activityBar.activeBorder": "#C27A45",
    "activityBar.background": "#F3EFE4",
    "activityBar.foreground": "#374151",
    "activityBarBadge.background": "#F59E0B",
    "activityBarBadge.foreground": "#1F2937",
    "button.background": "#F59E0B",
    "button.foreground": "#1F2937",
    "button.hoverBackground": "#FCD472",
    "editor.background": "#FAF7F0",
    "editor.foreground": "#1F2937",
    "editor.lineHighlightBackground": "#F3EFE4",
    "editor.selectionBackground": "#F59E0B33",
    "editorCursor.foreground": "#C27A45",
    "editorGroup.border": "#D6CFBE",
    "editorGroupHeader.tabsBackground": "#F3EFE4",
    "editorLineNumber.foreground": "#A89274",
    "editorLineNumber.activeForeground": "#B06535",
    "panel.background": "#F3EFE4",
    "panel.border": "#D6CFBE",
    "sideBar.background": "#F3EFE4",
    "sideBar.foreground": "#374151",
    "sideBar.border": "#D6CFBE",
    "sideBarTitle.foreground": "#1F2937",
    "statusBar.background": "#FAF7F0",
    "statusBar.foreground": "#B06535",
    "textLink.foreground": "#B06535",
    "gitDecoration.addedResourceForeground": "#2E7D32",
    "gitDecoration.deletedResourceForeground": "#D32F2F"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#A89274" }
    },
    {
      "scope": ["string", "constant.other.symbol"],
      "settings": { "foreground": "#B06535" }
    },
    {
      "scope": ["constant.numeric", "constant.language.boolean"],
      "settings": { "foreground": "#C27A45" }
    },
    {
      "scope": ["keyword", "keyword.control", "storage", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#B06535" }
    },
    {
      "scope": ["entity.name.type", "entity.other.inherited-class", "support.class", "support.type"],
      "settings": { "foreground": "#D98A53" }
    },
    {
      "scope": ["entity.name.function", "support.function", "variable.function", "meta.function-call"],
      "settings": { "foreground": "#1F2937" }
    },
    {
      "scope": ["variable", "variable.parameter"],
      "settings": { "foreground": "#374151" }
    },
    {
      "scope": ["punctuation", "meta.brace"],
      "settings": { "foreground": "#A89274" }
    }
  ]
}
