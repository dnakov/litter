{
  "name": "USGC Polyimide",
  "type": "dark",
  "colors": {
    "activityBar.background": "#0A0A0A",
    "activityBar.foreground": "#FFBF00",
    "button.background": "#FF6600",
    "button.foreground": "#000000",
    "button.hoverBackground": "#FFBF00",
    "editor.background": "#000000",
    "editor.foreground": "#FFBF00",
    "editor.lineHighlightBackground": "#0000FF",
    "editor.selectionBackground": "#000066",
    "editorCursor.foreground": "#00A645",
    "editorGroup.border": "#FF6600",
    "editorGroupHeader.tabsBackground": "#060606",
    "editorLineNumber.foreground": "#FF6600",
    "editorLineNumber.activeForeground": "#FFFFFF",
    "panel.background": "#060606",
    "panel.border": "#FF6600",
    "sideBar.background": "#060606",
    "sideBar.foreground": "#FFBF00",
    "sideBar.border": "#FF6600",
    "sideBarTitle.foreground": "#FFBF00",
    "statusBar.background": "#000000",
    "statusBar.foreground": "#FFBF00",
    "textLink.foreground": "#FFBF00",
    "gitDecoration.addedResourceForeground": "#00A645",
    "gitDecoration.deletedResourceForeground": "#FF0000"
  },
  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#999999" } },
    { "scope": ["string", "constant.other.symbol"], "settings": { "foreground": "#FFFF00" } },
    { "scope": ["constant.numeric", "constant.language.boolean"], "settings": { "foreground": "#00FFFF" } },
    { "scope": ["keyword", "storage", "storage.type", "storage.modifier"], "settings": { "foreground": "#FF6600" } },
    { "scope": ["entity.name.function", "support.function", "variable.function"], "settings": { "foreground": "#FFFFFF" } },
    { "scope": ["variable", "variable.parameter"], "settings": { "foreground": "#FFBF00" } }
  ]
}
