{
  "name": "Kitty Litter",
  "type": "dark",
  "colors": {
    "activityBar.activeBorder": "#F59E0B",
    "activityBar.background": "#2A3544",
    "activityBar.foreground": "#E5E7EB",
    "activityBarBadge.background": "#F59E0B",
    "activityBarBadge.foreground": "#1F2937",
    "button.background": "#F59E0B",
    "button.foreground": "#1F2937",
    "button.hoverBackground": "#FCD472",
    "editor.background": "#1F2937",
    "editor.foreground": "#E5E7EB",
    "editor.lineHighlightBackground": "#2A3544",
    "editor.selectionBackground": "#F59E0B40",
    "editorCursor.foreground": "#F59E0B",
    "editorGroup.border": "#374151",
    "editorGroupHeader.tabsBackground": "#2A3544",
    "editorLineNumber.foreground": "#6B7280",
    "editorLineNumber.activeForeground": "#FCD472",
    "panel.background": "#2A3544",
    "panel.border": "#374151",
    "sideBar.background": "#2A3544",
    "sideBar.foreground": "#E5E7EB",
    "sideBar.border": "#374151",
    "sideBarTitle.foreground": "#E5E7EB",
    "statusBar.background": "#1F2937",
    "statusBar.foreground": "#D98A53",
    "textLink.foreground": "#F59E0B",
    "gitDecoration.addedResourceForeground": "#6EA676",
    "gitDecoration.deletedResourceForeground": "#FF5555"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#6B7280" }
    },
    {
      "scope": ["string", "constant.other.symbol"],
      "settings": { "foreground": "#FCD472" }
    },
    {
      "scope": ["constant.numeric", "constant.language.boolean"],
      "settings": { "foreground": "#D98A53" }
    },
    {
      "scope": ["keyword", "keyword.control", "storage", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#F59E0B" }
    },
    {
      "scope": ["entity.name.type", "entity.other.inherited-class", "support.class", "support.type"],
      "settings": { "foreground": "#C27A45" }
    },
    {
      "scope": ["entity.name.function", "support.function", "variable.function", "meta.function-call"],
      "settings": { "foreground": "#E5E7EB" }
    },
    {
      "scope": ["variable", "variable.parameter"],
      "settings": { "foreground": "#D98A53" }
    },
    {
      "scope": ["punctuation", "meta.brace"],
      "settings": { "foreground": "#B06535" }
    }
  ]
}
