+    #[test]
+    fn dynamic_tool_call_arguments_delta_round_trips() {
+        let event = EventMsg::DynamicToolCallArgumentsDelta(DynamicToolCallArgumentsDeltaEvent {
+            thread_id: "thr_1".to_string(),
+            turn_id: "turn_1".to_string(),
+            item_id: "item_1".to_string(),
+            call_id: Some("call_1".to_string()),
+            delta: "{\"widget_code\":\"<svg".to_string(),
+        });
+
+        let json = serde_json::to_value(&event).expect("serialize");
+        assert_eq!(
+            json,
+            json!({
+                "type": "dynamic_tool_call_arguments_delta",
+                "thread_id": "thr_1",
+                "turn_id": "turn_1",
+                "item_id": "item_1",
+                "call_id": "call_1",
+                "delta": "{\"widget_code\":\"<svg"
+            })
+        );
+
+        let round_tripped: EventMsg = serde_json::from_value(json).expect("deserialize");
+        match round_tripped {
+            EventMsg::DynamicToolCallArgumentsDelta(payload) => {
+                assert_eq!(payload.thread_id, "thr_1");
+                assert_eq!(payload.turn_id, "turn_1");
+                assert_eq!(payload.item_id, "item_1");
+                assert_eq!(payload.call_id.as_deref(), Some("call_1"));
+                assert_eq!(payload.delta, "{\"widget_code\":\"<svg");
+            }
+            other => panic!("expected DynamicToolCallArgumentsDelta, got {other:?}"),
+        }
+    }
+
+    #[test]
+    fn dynamic_tool_call_arguments_delta_omits_call_id_when_none() {
+        let event = EventMsg::DynamicToolCallArgumentsDelta(DynamicToolCallArgumentsDeltaEvent {
+            thread_id: "thr_1".to_string(),
+            turn_id: "turn_1".to_string(),
+            item_id: "item_1".to_string(),
+            call_id: None,
+            delta: "abc".to_string(),
+        });
+        let json = serde_json::to_value(&event).expect("serialize");
+        assert!(json.get("call_id").is_none(), "got {json}");
+    }
 }
